# Copy this file to .env and fill in the values. .env is git-ignored.

# Public hostname this deployment is reachable at. Used by docker-compose
# (interpolated into the override file), the Caddyfile, gen-tls-certs.sh (cert
# CN/SAN), and the webapp/dserver env. Without it `docker compose up` and
# ./gen-tls-certs.sh both fail loudly.
DEPLOY_FQDN=

# OAuth2 (ORCID) credentials. Optional — the stack starts without them, but
# the OAuth2 login flow won't complete. Get them from
#   https://orcid.org/developer-tools           (production)
#   https://sandbox.orcid.org/developer-tools   (testing)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Copy this file to .env and fill in the values. .env is git-ignored.

# Public hostname this deployment is reachable at. Used by docker-compose (interpolated
# into the override file: Caddy network alias + dserver/index-s3 env). Without it
# `docker compose up` fails loudly. MUST equal the host named in caddy.json (Caddy JSON
# has no {$VAR} substitution, so the FQDN is hardcoded there — keep them in sync).
DEPLOY_FQDN=data.zhang-laboratory.org

# Optional: ACME contact email for Let's Encrypt (expiry notices). caddy.json works without
# it. If you want it applied, add it to the ACME issuer block in caddy.json (Caddy JSON
# does not read this env var automatically).
ACME_EMAIL=

# --- Remote S3 (MinIO) backend ------------------------------------------------------------
# The S3 storage backend is a REMOTE MinIO at 10.0.0.2:9000 (plain HTTP) reached over the
# WireGuard tunnel; Caddy's layer4 :9000 terminator fronts it with a valid TLS cert.
#
# S3_BUCKET: an EXISTING bucket on the remote MinIO (nothing in this stack creates it). Used
#   to build the dtool-s3 per-bucket env vars (DTOOL_S3_ENDPOINT_<bucket> etc.), the base URI
#   (s3://<bucket>), and indexing. Should be PRIVATE (presigned URLs are now load-bearing).
S3_BUCKET=

# Credentials for the remote MinIO (do NOT commit real values). dtool-s3 needs the
# access-key/secret pair alongside the endpoint for the chosen bucket.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- OAuth2 (ORCID) ----------------------------------------------------------------------
# Optional — the stack starts without them, but the OAuth2 login flow won't complete. Get
# them from
#   https://orcid.org/developer-tools           (production)
#   https://sandbox.orcid.org/developer-tools   (testing)
# Register the redirect URI exactly: https://${DEPLOY_FQDN}/lookup/auth/callback
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# --- SAML SP (THERS 機構統合認証サービス / 機構IdP) ---------------------------------------
# The SAML token-generator plugin is installed (INSTALL_SAML_PLUGIN=true in the override) and
# mounted at /lookup/auth/saml (alongside /auth/oauth2 and /auth/ldap). The SP keypair is
# auto-generated on first boot; the SP entityID and metadata are fixed
# (https://${DEPLOY_FQDN}/lookup/auth/saml/metadata). Workflow:
#   1. Bring the stack up; fetch the SP metadata from
#      https://${DEPLOY_FQDN}/lookup/auth/saml/metadata and submit it to THERS with the
#      機構統合認証サービス利用申請 (sysop@t.thers.ac.jp).
#   2. When THERS grants access, point at their IdP metadata + entityID below, then restart
#      dserver. /lookup/auth/saml/login then runs the real round-trip.
#
# PREFER the remote metadata URL over a static file: THERS rotates the IdP SAML cert to a
# self-signed one (~2027-03); the remote URL keeps the embedded signing cert current, while a
# static file would go stale and break signature validation (pysaml2 uses metadata/explicit-
# key trust, not a CA chain).
#   Production IdP: SAML_IDP_METADATA_URL=https://shib.sys.thers.ac.jp/idp/shibboleth
#                   SAML_IDP_ENTITY_ID=https://shib.sys.thers.ac.jp/idp/shibboleth
#   Test IdP:       different URL/entityID, provided by THERS on approval.
SAML_IDP_METADATA_URL=
SAML_IDP_METADATA_FILE=
SAML_IDP_ENTITY_ID=
# Attribute release → dserver username. Default = Shibboleth/GakuNin convention (ePPN).
# CONFIRM against THERS's actual released attributes and adjust if their stable id differs.
SAML_ATTRIBUTE_MAP=eduPersonPrincipalName:user_id,mail:email,displayName:display_name
SAML_USERNAME_FIELD=user_id
